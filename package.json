{
  "name": "iptv-player",
  "version": "0.1.0",
  "description": "Xtream Codes IPTV Player for Windows",
  "author": "Malak Ettabia",
  "main": "dist-electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "electron:dev": "concurrently -k \"ng serve\" \"wait-on http://localhost:4200 && npm run build:electron && electron .\"",
    "electron:build": "ng build --configuration production && npm run build:electron && electron-builder --win",
    "watch": "ng build --watch --configuration development"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/cdk": "^18.2.14",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/router": "^18.2.0",
    "electron-store": "^8.2.0",
    "hls.js": "^1.5.15",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.0",
    "@angular/cli": "^18.2.0",
    "@angular/compiler-cli": "^18.2.0",
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.2",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "~5.5.2",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.malakettabia.iptvplayer",
    "productName": "IPTV Player",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/iptv-player/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
